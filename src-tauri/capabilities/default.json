{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the cardgrab desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:webview:default",
    "core:path:default",
    "core:app:default",
    "dialog:default",
    "shell:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir"
  ]
}
