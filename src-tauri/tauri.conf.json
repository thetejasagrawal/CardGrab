{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cardgrab",
  "version": "0.1.0",
  "identifier": "com.cardgrab.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cardgrab",
        "width": 1080,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "decorations": true,
        "shadow": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Library/Application Support/cardgrab/thumbs/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "category": "Photography",
    "shortDescription": "Fast, complete SD card ingest",
    "longDescription": "Mac-first SD card ingest that handles photo and video at full reader speed, with smart folder templates and a local import journal.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {}
}
